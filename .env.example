# Nome do banco de dados PostgreSQL (ex.: restaurant_management)
SPRING_DATASOURCE_DATABASE=

# Credenciais do banco de dados (ex.: username e password do PostgreSQL)
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Porta do PostgreSQL exposta no host (mapeada para 5432 no container)
SPRING_DATASOURCE_PORT=

# Porta da aplicação exposta no host (mapeada para 8080 no container)
APP_PORT=

# JWT secret em Base64. Gere com: openssl rand -base64 32
JWT_SECRET=replace-with-base64-secret

# Expiracao do access token em minutos (ex.: 15 para 15 minutos)
JWT_ACCESS_TOKEN_EXPIRATION_TIME=
